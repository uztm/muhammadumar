# ===========================================================================
# GovBot — root environment template (used by docker-compose.yml)
# Copy to `.env` and fill in real values. NEVER commit the real .env.
# ===========================================================================

# ---- PostgreSQL (db service) ----
POSTGRES_DB=govbot
POSTGRES_USER=govbot
POSTGRES_PASSWORD=change-me-in-prod
POSTGRES_HOST=db
POSTGRES_PORT=5432

# ---- Django backend ----
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1,backend
# Single URL alternative to the discrete POSTGRES_* vars above:
DATABASE_URL=postgres://govbot:change-me-in-prod@db:5432/govbot
FRONTEND_ORIGIN=http://localhost:5173
ACCESS_TOKEN_LIFETIME_MIN=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- OpenAI ----
# Leave OPENAI_API_KEY blank to run in mock mode (no external calls).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1200
OPENAI_TEMPERATURE=0.3

# ---- Frontend (Vite) — injected at build time ----
VITE_API_BASE_URL=http://localhost:8000/api
