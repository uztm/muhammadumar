# ---- Django ----
SECRET_KEY=change-me-to-a-long-random-string
DEBUG=1
ALLOWED_HOSTS=localhost,127.0.0.1

# ---- Database ----
# Option A: single URL (takes priority)
# DATABASE_URL=postgres://govbot:password@localhost:5432/govbot
# Option B: discrete vars
# POSTGRES_DB=govbot
# POSTGRES_USER=govbot
# POSTGRES_PASSWORD=password
# POSTGRES_HOST=localhost
# POSTGRES_PORT=5432
# If neither is set, a local SQLite db (db.sqlite3) is used automatically.

# ---- JWT lifetimes ----
ACCESS_TOKEN_LIFETIME_MIN=60
REFRESH_TOKEN_LIFETIME_DAYS=7

# ---- CORS ----
FRONTEND_ORIGIN=http://localhost:5173

# ---- OpenAI ----
# Leave OPENAI_API_KEY blank to run in mock mode (no external calls).
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1200
OPENAI_TEMPERATURE=0.3
