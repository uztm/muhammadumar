# ===========================================================================
# GovBot — PRODUCTION environment template (used by docker-compose.prod.yml).
# On the server: copy to `.env`, fill real values, then run the deploy.
# NEVER commit the real .env.
# ===========================================================================

# Public port the app is served on.
PUBLIC_PORT=6969

# ---- Django ----
DEBUG=0
SECRET_KEY=CHANGE-ME-to-a-long-random-string
# Host/IP (or domain) the app is reached at. Comma-separated. 'backend' is the
# internal service name used by the nginx proxy.
ALLOWED_HOSTS=13.140.171.116,localhost,127.0.0.1,backend
# Needed so the Django admin login works over the server IP+port.
CSRF_TRUSTED_ORIGINS=http://13.140.171.116:6969
FRONTEND_ORIGIN=http://13.140.171.116:6969

# ---- PostgreSQL ----
POSTGRES_DB=govbot
POSTGRES_USER=govbot
POSTGRES_PASSWORD=CHANGE-ME-strong-db-password

# ---- OpenAI ----
OPENAI_API_KEY=
OPENAI_MODEL=gpt-4o-mini
OPENAI_MAX_TOKENS=1200
OPENAI_TEMPERATURE=0.3

# ---- Frontend build ----
# Single-origin: leave as /api so the browser calls the same host:port.
VITE_API_BASE_URL=/api
